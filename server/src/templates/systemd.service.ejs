[Unit]
Description=FrostDeploy: <%= name %>
After=network.target

[Service]
Type=simple
User=<%= runUser || 'root' %>
WorkingDirectory=<%= runtimeDir %>
ExecStart=/usr/bin/npm start
Restart=on-failure
RestartSec=5
Environment=PORT=<%= port %>
Environment=NODE_ENV=production
Environment=PATH=<% if (extraPath) { %><%= extraPath %>:<% } %>/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
<% if (envFilePath) { %>
EnvironmentFile=<%= envFilePath %>
<% } %>
<% if (cpuQuota) { %>
CPUQuota=<%= cpuQuota %>
<% } %>
<% if (memoryMax) { %>
MemoryMax=<%= memoryMax %>
<% } %>
<% if (limitNofile) { %>
LimitNOFILE=<%= limitNofile %>
<% } %>
StandardOutput=journal
StandardError=journal
SyslogIdentifier=frostdeploy-<%= name %>

[Install]
WantedBy=multi-user.target
